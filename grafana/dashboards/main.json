      "targets": [{"expr": "urlpulse_active_urls", "refId": "A"}],
      "title": "Active URLs",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"unit": "none"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
