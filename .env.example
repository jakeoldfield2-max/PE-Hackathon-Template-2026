FLASK_DEBUG=true

# Common Standard Profile (Docker-first)
# This is the default profile used by docker-compose.
# Change placeholder values before running in shared/public environments.

# --- App DB connection ---
DATABASE_NAME=hackathon_db
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=__SET_DATABASE_PASSWORD__

# --- Postgres container bootstrap ---
# Keep these aligned with DATABASE_* for local Docker usage.
POSTGRES_DB=hackathon_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__SET_DATABASE_PASSWORD__

# --- Redis connection ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Observability credentials ---
GRAFANA_ADMIN_USER=__SET_GRAFANA_ADMIN_USER__
GRAFANA_ADMIN_PASSWORD=__SET_GRAFANA_ADMIN_PASSWORD__
DISCORD_WEBHOOK_URL=__SET_DISCORD_WEBHOOK_URL__

# Optional overrides (no need to uncomment large blocks):
# 1) Local app run (outside Docker): set DATABASE_HOST=localhost and REDIS_HOST=localhost
# 2) Supabase: replace DATABASE_* with Supabase connection values
