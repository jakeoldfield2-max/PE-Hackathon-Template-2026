FLASK_DEBUG=true

# --- Database ---
# Option A: Supabase (recommended for teams — shared DB, no local setup)
# Get these from: Supabase Dashboard → Connect → Connection string
DATABASE_NAME=postgres
DATABASE_HOST=aws-0-<region>.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_USER=postgres.<your-project-ref>
DATABASE_PASSWORD=<your-supabase-password>

# Option B: Local PostgreSQL
# DATABASE_NAME=hackathon_db
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=<your-local-password>

# Option C: Docker Compose (used automatically by docker-compose.yml)
# DATABASE_NAME=hackathon_db
# DATABASE_HOST=postgres
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=<your-docker-password>
# POSTGRES_DB=hackathon_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=<your-docker-password>

# --- Redis (Docker only) ---
# REDIS_HOST=redis
# REDIS_PORT=6379
